<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/assets/styles.css" id="mainStylesheet">
  <style id="inlineStyles">
    #myVideo {
            position: fixed;
            right: 0;
            bottom: 0;
            min-width: 100%;
            min-height: 100%;
            z-index: -1;
        }

    /* ── Profile picture picker ── */
    .profile-pic-picker {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin: 8px 0 18px;
    }

    .profile-pic-option {
      position: relative;
      cursor: pointer;
      border-radius: 50%;
      display: block;
    }

    /* hide the actual radio button */
    .profile-pic-option input[type="radio"] {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }

    .profile-pic-option img {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid transparent;
      transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
      display: block;
    }

    .profile-pic-option img:hover {
      border-color: #aaa;
      transform: scale(1.07);
    }

    /* tick overlay — hidden by default */
    .profile-pic-tick {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      color: #fff;
      background: rgba(0,0,0,0.45);
      opacity: 0;
      transition: opacity 0.15s;
      pointer-events: none;
    }

    /* selected state */
    .profile-pic-option input[type="radio"]:checked ~ img {
      border-color: #4CAF50;
      box-shadow: 0 0 0 3px rgba(76,175,80,0.35);
      transform: scale(1.1);
    }

    .profile-pic-option input[type="radio"]:checked ~ .profile-pic-tick {
      opacity: 1;
    }
  </style>
</head>

