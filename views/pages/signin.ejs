<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/assets/styles.css" id="mainStylesheet">
  <link rel="stylesheet" href="/assets/wheelygood.css">
  <style id="inlineStyles">
    #myVideo {
            position: fixed;
            right: 0;
            bottom: 0;
            min-width: 100%;
            min-height: 100%;
            z-index: -1;
        }

    /* NeveMurchie Password Warning Modal */
    .nevemurchie-modal {
      display: none;
      position: fixed;
      z-index: 9999999;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.8);
      animation: fadeIn 0.3s;
    }

    .nevemurchie-modal-content {
      background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
      margin: 15% auto;
      padding: 30px;
      border: 5px solid #000;
      width: 80%;
      max-width: 500px;
      border-radius: 20px;
      box-shadow: 0 0 50px rgba(255, 107, 107, 0.8);
      animation: slideIn 0.3s, shake 0.5s infinite;
      text-align: center;
    }

    .nevemurchie-modal-content h2 {
      color: white;
      font-size: 28px;
      margin-bottom: 20px;
      text-shadow: 3px 3px 0 #000;
    }

    .nevemurchie-modal-content p {
      color: white;
      font-size: 18px;
      margin-bottom: 25px;
      font-weight: bold;
    }

    .nevemurchie-buttons {
      display: flex;
      gap: 15px;
      justify-content: center;
    }

    .nevemurchie-btn {
      padding: 15px 30px;
      font-size: 18px;
      font-weight: bold;
      border: 3px solid #000;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.3s;
    }

    .nevemurchie-btn.yes {
      background: #27ae60;
      color: white;
    }

    .nevemurchie-btn.yes:hover {
      background: #2ecc71;
      transform: scale(1.1);
    }

    .nevemurchie-btn.no {
      background: #c0392b;
      color: white;
    }

    .nevemurchie-btn.no:hover {
      background: #e74c3c;
      transform: scale(1.1);
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes slideIn {
      from { transform: translateY(-50px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    @keyframes shake {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(-1deg); }
      75% { transform: rotate(1deg); }
    }

    /* ── Profile picture picker ── */
    .profile-pic-picker {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin: 8px 0 18px;
    }

    .profile-pic-option {
      position: relative;
      cursor: pointer;
      border-radius: 50%;
      display: block;
    }

    /* hide the actual radio button */
    .profile-pic-option input[type="radio"] {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }

    .profile-pic-option img {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid transparent;
      transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
      display: block;
    }

    .profile-pic-option img:hover {
      border-color: #aaa;
      transform: scale(1.07);
    }

    /* tick overlay — hidden by default */
    .profile-pic-tick {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      color: #fff;
      background: rgba(0,0,0,0.45);
      opacity: 0;
      transition: opacity 0.15s;
      pointer-events: none;
    }

    /* selected state */
    .profile-pic-option input[type="radio"]:checked ~ img {
      border-color: #4CAF50;
      box-shadow: 0 0 0 3px rgba(76,175,80,0.35);
      transform: scale(1.1);
    }

    .profile-pic-option input[type="radio"]:checked ~ .profile-pic-tick {
      opacity: 1;
    }

    /* ── Birthday Dartboard ── */
    .dart-score-display {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
      padding: 10px 15px;
      background: #0a0a0a;
      border-radius: 8px;
      border: 1px solid #333;
    }

    .dart-score-display div {
      color: #fff;
      font-size: 14px;
    }

    .dart-score-display .score-value {
      color: #4CAF50;
      font-weight: bold;
      font-size: 18px;
    }

    .dartboard-container {
      display: flex;
      justify-content: center;
      margin: 15px 0;
      position: relative;
    }

    #dartboard {
      width: 400px;
      height: 400px;
      cursor: crosshair;
      transition: transform 0.1s;
      filter: drop-shadow(0 0 10px rgba(0,0,0,0.5));
    }

    #dartboard:hover {
      filter: drop-shadow(0 0 15px rgba(255,255,255,0.2));
    }

    #dartboard.aiming {
      animation: boardJitter 0.15s infinite;
    }

    #dartboard.aiming-wild {
      animation: boardJitterWild 0.1s infinite;
    }

    @keyframes boardJitter {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      25% { transform: translate(-1px, 1px) rotate(-0.3deg); }
      50% { transform: translate(1px, -1px) rotate(0.3deg); }
      75% { transform: translate(-1px, -1px) rotate(-0.2deg); }
    }

    @keyframes boardJitterWild {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      10% { transform: translate(-6px, 4px) rotate(-4deg); }
      20% { transform: translate(6px, -4px) rotate(4deg); }
      30% { transform: translate(-4px, 6px) rotate(-3deg); }
      40% { transform: translate(4px, -6px) rotate(3deg); }
      50% { transform: translate(-8px, 2px) rotate(-5deg); }
      60% { transform: translate(8px, -2px) rotate(5deg); }
      70% { transform: translate(-2px, 8px) rotate(-2deg); }
      80% { transform: translate(2px, -8px) rotate(2deg); }
      90% { transform: translate(-6px, -4px) rotate(-4deg); }
    }


    .score-popup {
      position: absolute;
      color: #ffd700;
      font-weight: bold;
      font-size: 20px;
      pointer-events: none;
      z-index: 101;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
      animation: scoreFloat 1s ease-out forwards;
    }

    @keyframes scoreFloat {
      0% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
      100% {
        opacity: 0;
        transform: translateY(-40px) scale(1.2);
      }
    }

    .dart-controls {
      display: flex;
      gap: 10px;
      justify-content: center;
      margin: 15px 0;
    }

    .dart-controls button {
      padding: 10px 20px;
      font-size: 14px;
      font-weight: bold;
      border: 2px solid #000;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .dart-controls button.clear-btn {
      background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
      color: white;
    }

    .dart-controls button.clear-btn:hover {
      background: linear-gradient(135deg, #ff6b6b 0%, #e74c3c 100%);
      transform: scale(1.05);
    }

    .dart-controls button.year-btn {
      background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
      color: white;
      min-width: 150px;
    }

    .dart-controls button.year-btn:hover {
      background: linear-gradient(135deg, #5dade2 0%, #3498db 100%);
      transform: scale(1.05);
    }

    .birthday-result {
      text-align: center;
      padding: 12px;
      background: #0a0a0a;
      border-radius: 8px;
      border: 1px solid #333;
      margin-top: 10px;
    }

    .birthday-result div {
      color: #aaa;
      font-size: 13px;
      margin: 5px 0;
    }

    .birthday-result .result-value {
      color: #4CAF50;
      font-weight: bold;
      font-size: 16px;
    }

    .birthday-result .result-value.complete {
      color: #2ecc71;
      font-size: 18px;
    }
  </style>
</head>

