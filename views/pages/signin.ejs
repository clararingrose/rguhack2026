<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/assets/styles.css" id="mainStylesheet">
  <style id="inlineStyles">
    #myVideo {
            position: fixed;
            right: 0;
            bottom: 0;
            min-width: 100%;
            min-height: 100%;
            z-index: -1;
        }

    /* NeveMurchie Password Warning Modal */
    .nevemurchie-modal {
      display: none;
      position: fixed;
      z-index: 9999999;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.8);
      animation: fadeIn 0.3s;
    }

    .nevemurchie-modal-content {
      background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
      margin: 15% auto;
      padding: 30px;
      border: 5px solid #000;
      width: 80%;
      max-width: 500px;
      border-radius: 20px;
      box-shadow: 0 0 50px rgba(255, 107, 107, 0.8);
      animation: slideIn 0.3s, shake 0.5s infinite;
      text-align: center;
    }

    .nevemurchie-modal-content h2 {
      color: white;
      font-size: 28px;
      margin-bottom: 20px;
      text-shadow: 3px 3px 0 #000;
    }

    .nevemurchie-modal-content p {
      color: white;
      font-size: 18px;
      margin-bottom: 25px;
      font-weight: bold;
    }

    .nevemurchie-buttons {
      display: flex;
      gap: 15px;
      justify-content: center;
    }

    .nevemurchie-btn {
      padding: 15px 30px;
      font-size: 18px;
      font-weight: bold;
      border: 3px solid #000;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.3s;
    }

    .nevemurchie-btn.yes {
      background: #27ae60;
      color: white;
    }

    .nevemurchie-btn.yes:hover {
      background: #2ecc71;
      transform: scale(1.1);
    }

    .nevemurchie-btn.no {
      background: #c0392b;
      color: white;
    }

    .nevemurchie-btn.no:hover {
      background: #e74c3c;
      transform: scale(1.1);
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes slideIn {
      from { transform: translateY(-50px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    @keyframes shake {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(-1deg); }
      75% { transform: rotate(1deg); }
    }

    /* ── Profile picture picker ── */
    .profile-pic-picker {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin: 8px 0 18px;
    }

    .profile-pic-option {
      position: relative;
      cursor: pointer;
      border-radius: 50%;
      display: block;
    }

    /* hide the actual radio button */
    .profile-pic-option input[type="radio"] {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }

    .profile-pic-option img {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid transparent;
      transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
      display: block;
    }

    .profile-pic-option img:hover {
      border-color: #aaa;
      transform: scale(1.07);
    }

    /* tick overlay — hidden by default */
    .profile-pic-tick {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      color: #fff;
      background: rgba(0,0,0,0.45);
      opacity: 0;
      transition: opacity 0.15s;
      pointer-events: none;
    }

    /* selected state */
    .profile-pic-option input[type="radio"]:checked ~ img {
      border-color: #4CAF50;
      box-shadow: 0 0 0 3px rgba(76,175,80,0.35);
      transform: scale(1.1);
    }

    .profile-pic-option input[type="radio"]:checked ~ .profile-pic-tick {
      opacity: 1;
    }

    /* ── Binary Switch Phone Input ── */
    .binary-switch-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin: 8px 0 18px;
    }

    .binary-switches-grid {
      display: grid;
      grid-template-columns: repeat(11, 1fr);
      gap: 6px;
      padding: 10px;
      background: rgba(0, 0, 0, 0.2);
      border-radius: 8px;
    }

    .binary-switch-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }

    .binary-checkbox {
      width: 24px;
      height: 24px;
      cursor: pointer;
      accent-color: #4CAF50;
    }

    .bit-label {
      font-size: 9px;
      color: #888;
      font-family: monospace;
    }

    .binary-preview {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 10px;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 6px;
      font-family: monospace;
    }

    .binary-preview-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .binary-preview-label {
      color: #aaa;
      font-size: 12px;
    }

    .binary-preview-value {
      color: #4CAF50;
      font-size: 14px;
      font-weight: bold;
      word-break: break-all;
    }

    .binary-preview-value.binary {
      color: #3498db;
      font-size: 11px;
      letter-spacing: 1px;
    }

    .binary-preview-value.invalid {
      color: #e74c3c;
    }

    .binary-phone-display {
      font-size: 16px;
      color: #fff;
      font-weight: bold;
      text-align: center;
      padding: 8px;
      background: rgba(76, 175, 80, 0.2);
      border-radius: 6px;
      border: 2px solid #4CAF50;
    }

    .binary-phone-display.invalid {
      background: rgba(231, 76, 60, 0.2);
      border-color: #e74c3c;
    }

    .binary-error-message {
      font-size: 12px;
      color: #e74c3c;
      text-align: center;
      min-height: 16px;
    }
  </style>
</head>

<body>
<%- include('../partials/nav') %>

    <video autoplay muted loop id="myVideo">
        <source src="assets/fire.mp4" type="video/mp4">
    </video>

    <!-- Color Blind Mode Toggle -->
    <!-- <button class="colorblind-toggle" id="colorblindToggle" style="position: fixed; top: 10px; right: 10px; z-index: 999999; padding: 10px; background: white; border: 2px solid black; color: black; font-size: 16px; cursor: pointer; font-weight: bold;" title="Toggle Color Blind Mode">Disable CSS</button> -->

<form style="border:1px solid #ccc">
  <div class="container">
    <h1 style="font-family: deathZombie">Evil Sign Up</h1>
    <p>Please fill in this form to create an account.</p>
    <hr>
    <label for="firstname"><b>First Name</b></label>
    <input type="text" placeholder="Enter First Name" name="firstname" required>

    <label for="middlename"><b>Middle Name</b></label>
    <input type="text" placeholder="Enter Middle Name" name="middlename" required>

    <label for="lastname"><b>Last Name</b></label>
    <input type="text" placeholder="Enter Last Name" name="lastname" required>

    <label for="zodiacsign"><b>Zodiac Sign</b></label>
    <input type="text" placeholder="Enter Zodiac Sign" name="zodiacsign" required>

    <label for="email"><b>Email</b></label>
    <input type="text" placeholder="Enter Email" name="email" required>

    <label for="psw"><b>Password</b></label>
    <input type="password" placeholder="Enter Password" name="psw" required>

    <label for="psw-repeat"><b>Repeat Password</b></label>
    <input type="password" placeholder="Repeat Password" name="psw-repeat" required>

    <label for="psw-repeat"><b>Repeat Password</b></label>
    <input type="password" placeholder="Repeat Password" name="psw-repeat" required>

    <label for="psw-repeat"><b>Repeat Password</b></label>
    <input type="password" placeholder="Repeat Password" name="psw-repeat" required>

    <label for="email-repeat"><b>Repeat Email</b></label>
    <input type="text" placeholder="Repeat Email" name="email-repeat" required>

    <label for="psw-repeat"><b>Repeat Password</b></label>
    <input type="password" placeholder="Repeat Password" name="psw-repeat" required>

    <label><b>Profile Picture</b></label>
    <div class="profile-pic-picker">
      <% if (typeof profilePics !== 'undefined' && profilePics.length > 0) { %>
        <% profilePics.forEach(pic => { %>
          <label class="profile-pic-option">
            <input type="radio" name="profilepic" value="<%= pic %>" required>
            <img src="/assets/profilepics/<%= pic %>" alt="<%= pic %>" title="<%= pic %>">
            <span class="profile-pic-tick">✓</span>
          </label>
        <% }) %>
      <% } else { %>
        <p style="color:#aaa; font-style:italic">No profile pictures found.</p>
      <% } %>
    </div>
    <!-- Hidden fallback so the selected value is always submitted -->
    <input type="hidden" name="profilepic" id="profilepicHidden">

    <label>
      <input type="checkbox" checked="checked" name="remember" style="margin-bottom:15px"> Forget to Not Remember to Forget about Remembering me?
    </label>

    <label for="address"><b>Where are you even?</b></label>
    <input type="text" placeholder="Enter Adress" name="adress" required>

    <label for="postcode"><b>postcode</b></label>
    <input type="text" placeholder="Enter postcode" name="postcode" required>

    <label for="cvv"><b>cvv</b></label>
    <input type="text" placeholder="Enter cvv" name="cvv" required>

    <label for="phone"><b>Home Phone</b></label>
    <p style="font-size:12px; color:#888; margin:2px 0 6px;">Toggle the switches to enter your phone number in binary!</p>

    <div class="binary-switch-container" id="binarySwitchContainer">
      <div class="binary-switches-grid" id="binarySwitchesGrid"></div>
      <div class="binary-preview">
        <div class="binary-preview-row">
          <span class="binary-preview-label">Decimal:</span>
          <span class="binary-preview-value" id="decimalPreview">0</span>
        </div>
      </div>
      <div class="binary-phone-display" id="phoneDisplay">0</div>
      <div class="binary-error-message" id="binaryError"></div>
      <input type="hidden" name="phone" id="phoneDigits" required>
    </div>

    <label for="middlename"><b>Middle Name</b></label>
    <input type="text" placeholder="Enter Middle Name" name="middlename" required>
    

    <p>By creating an account you agree to our <a href="#" style="color:dodgerblue">Terms & Privacy</a>.</p>

    <div class="clearfix">
      <button type="button" class="cancelbtn">Cancel</button>
      <button type="submit" class="signupbtn">Sign Up</button>
    </div>
  </div>
</form>

<script src="/js/colorblind-mode.js"></script>

<!-- NeveMurchie Password Warning Modal -->
<div id="nevemurchieModal" class="nevemurchie-modal">
  <div class="nevemurchie-modal-content">
    <h2>⚠️ PASSWORD WARNING ⚠️</h2>
    <p>This password is already in use by <strong>NeveMurchie</strong>.</p>
    <p>Are you sure you want to use it?</p>
    <div class="nevemurchie-buttons">
      <button class="nevemurchie-btn yes" onclick="proceedWithSignup()">Yes, I'm Sure</button>
      <button class="nevemurchie-btn no" onclick="closeNeveMurchieModal()">No, Let Me Change It</button>
    </div>
  </div>
</div>

<script>
  const form = document.querySelector('form');
  const modal = document.getElementById('nevemurchieModal');

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    modal.style.display = 'block';
  });

  function closeNeveMurchieModal() {
    modal.style.display = 'none';
  }

  function proceedWithSignup() {
    modal.style.display = 'none';
    window.location.href = '/';
  }

  // Close modal if clicking outside
  window.onclick = function(event) {
    if (event.target == modal) {
      modal.style.display = 'none';
    }
  }
</script>
<script>
  // Keep the hidden input in sync so the selected pic is always submitted
  document.querySelectorAll('input[name="profilepic"][type="radio"]').forEach(radio => {
    radio.addEventListener('change', () => {
      document.getElementById('profilepicHidden').value = radio.value;
    });
  });
</script>

<%- include("../partials/wheel.ejs") %>

<script>
  // ── Binary Switch Phone Number Input ──────────────────────────────────────
  const NUM_SWITCHES = 33;
  const switchStates = new Array(NUM_SWITCHES).fill(0);

  const binarySwitchesGrid = document.getElementById('binarySwitchesGrid');
  const decimalPreview = document.getElementById('decimalPreview');
  const phoneDisplay = document.getElementById('phoneDisplay');
  const binaryError = document.getElementById('binaryError');
  const phoneDigits = document.getElementById('phoneDigits');

  // Generate the checkboxes dynamically (reverse order: bit 32 on left, bit 0 on right)
  function createSwitches() {
    for (let i = NUM_SWITCHES - 1; i >= 0; i--) {
      const wrapper = document.createElement('div');
      wrapper.className = 'binary-switch-wrapper';

      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.className = 'binary-checkbox';
      checkbox.dataset.bitIndex = i;
      checkbox.addEventListener('change', handleSwitchToggle);

      const bitLabel = document.createElement('span');
      bitLabel.className = 'bit-label';
      bitLabel.textContent = i;

      wrapper.appendChild(checkbox);
      wrapper.appendChild(bitLabel);
      binarySwitchesGrid.appendChild(wrapper);
    }
  }

  // Handle checkbox toggle
  function handleSwitchToggle(event) {
    const bitIndex = parseInt(event.target.dataset.bitIndex);
    switchStates[bitIndex] = event.target.checked ? 1 : 0;
    updateDisplay();
  }

  // Convert binary array to decimal
  function binaryToDecimal(states) {
    let decimal = 0n;
    for (let i = 0; i < states.length; i++) {
      if (states[i] === 1) {
        decimal += BigInt(2) ** BigInt(i);
      }
    }
    return decimal;
  }

  // Validate phone number (ITU-T E.164: 7-15 digits)
  function validatePhoneNumber(decimalStr) {
    const digits = decimalStr.replace(/\D/g, '');
    if (digits.length < 7) {
      return 'Phone number too short (minimum 7 digits)';
    }
    if (digits.length > 15) {
      return 'Phone number too long (maximum 15 digits)';
    }
    return null;
  }

  // Update all display elements
  function updateDisplay() {
    const decimal = binaryToDecimal(switchStates);
    const decimalStr = decimal.toString();

    // Update preview display
    decimalPreview.textContent = decimalStr;

    // Validate phone number
    const error = validatePhoneNumber(decimalStr);

    if (error) {
      phoneDisplay.textContent = decimalStr;
      phoneDisplay.classList.add('invalid');
      decimalPreview.classList.add('invalid');
      binaryError.textContent = error;
      phoneDigits.value = '';
    } else {
      phoneDisplay.textContent = decimalStr;
      phoneDisplay.classList.remove('invalid');
      decimalPreview.classList.remove('invalid');
      binaryError.textContent = '';
      phoneDigits.value = decimalStr;
    }
  }

  // Initialize switches on page load
  createSwitches();
  updateDisplay();
</script>
</body>
</html>