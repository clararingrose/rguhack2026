<script>
  // ── Word-to-digit phone number parser ──────────────────────────────────
  const WORD_MAP = {
    // digits
    'zero':0,'one':1,'two':2,'three':3,'four':4,
    'five':5,'six':6,'seven':7,'eight':8,'nine':9,
    // teens/tens (in case someone gets creative)
    'ten':10,'eleven':11,'twelve':12,'thirteen':13,'fourteen':14,
    'fifteen':15,'sixteen':16,'seventeen':17,'eighteen':18,'nineteen':19,
    'twenty':20,'thirty':30,'forty':40,'fifty':50,
    'sixty':60,'seventy':70,'eighty':80,'ninety':90,
    // plus / hash symbols
    'plus':'+','hash':'#','star':'*','pound':'#',
  };

  // Single digits AND symbols we expect
  const VALID_PHONE_CHARS = /^[0-9+#*]+$/;

  function parsePhoneWords(input) {
    const tokens = input.trim().toLowerCase().split(/\s+/);
    const errors = [];
    let result = '';

    for (const token of tokens) {
      if (token === '') continue;
      if (token in WORD_MAP) {
        const val = WORD_MAP[token];
        // Only allow single digits and symbols in phone numbers
        if (typeof val === 'number' && val > 9) {
          errors.push(`"${token}" is not a single digit — use individual digit words`);
        } else {
          result += val;
        }
      } else {
        errors.push(`"${token}" is not a recognised digit word`);
      }
    }

    return { result, errors };
  }

  function validatePhone(digits) {
    // Strip the leading + for length check
    const stripped = digits.replace(/^\+/, '');
    if (stripped.length < 7)  return 'Phone number is too short (minimum 7 digits)';
    if (stripped.length > 15) return 'Phone number is too long (maximum 15 digits, per ITU-T E.164)';
    return null;
  }

  const phoneWordsInput = document.getElementById('phoneWords');
  const phonePreview    = document.getElementById('phonePreview');
  const phoneError      = document.getElementById('phoneError');
  const phoneDigits     = document.getElementById('phoneDigits');

  phoneWordsInput.addEventListener('input', () => {
    const raw = phoneWordsInput.value;
    if (!raw.trim()) {
      phonePreview.textContent = '';
      phoneError.textContent   = '';
      phoneDigits.value        = '';
      return;
    }

    const { result, errors } = parsePhoneWords(raw);

    if (errors.length) {
      phonePreview.textContent = result ? `Parsed so far: ${result}` : '';
      phoneError.textContent   = errors[0]; // show first error only
      phoneDigits.value        = '';
      phoneWordsInput.setCustomValidity(errors[0]);
    } else {
      const lenError = validatePhone(result);
      if (lenError) {
        phonePreview.textContent = `Parsed: ${result}`;
        phoneError.textContent   = lenError;
        phoneDigits.value        = '';
        phoneWordsInput.setCustomValidity(lenError);
      } else {
        phonePreview.textContent = `✓ ${result}`;
        phonePreview.style.color = '#27ae60';
        phoneError.textContent   = '';
        phoneDigits.value        = result;
        phoneWordsInput.setCustomValidity('');
      }
    }
  });
</script>

<script>
  // ── Binary checkbox phone number input ────────────────────────────────
  (function() {
    const NUM_BITS = 33; // 11 columns × 3 rows = 33 bits
    const MIN_PHONE_DIGITS = 7;
    const MAX_PHONE_DIGITS = 10;

    const checkboxGrid = document.getElementById('binaryCheckboxGrid');
    const preview = document.getElementById('binaryPhonePreview');
    const errorDisplay = document.getElementById('binaryPhoneError');
    const hiddenInput = document.getElementById('phoneBinaryDigits');

    // Generate checkboxes (MSB to LSB for left-to-right reading)
    for (let i = NUM_BITS - 1; i >= 0; i--) {
      const label = document.createElement('label');
      label.style.cssText = 'display:flex; flex-direction:column; align-items:center; cursor:pointer;';

      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.dataset.bitPosition = i;
      checkbox.style.cssText = 'width:16px; height:16px; cursor:pointer;';

      const bitLabel = document.createElement('span');
      bitLabel.textContent = i;
      bitLabel.style.cssText = 'font-size:7px; color:#555; margin-top:2px;';

      label.appendChild(checkbox);
      label.appendChild(bitLabel);
      checkboxGrid.appendChild(label);

      checkbox.addEventListener('change', updateBinaryPhone);
    }

    function updateBinaryPhone() {
      let decimalValue = 0n;

      // Calculate decimal value from checked bits
      document.querySelectorAll('#binaryCheckboxGrid input[type="checkbox"]').forEach(cb => {
        if (cb.checked) {
          const bitPos = parseInt(cb.dataset.bitPosition);
          decimalValue += (1n << BigInt(bitPos));
        }
      });

      const decimalStr = decimalValue.toString();
      preview.textContent = decimalStr;

      // Validate phone number length
      if (decimalStr.length < MIN_PHONE_DIGITS && decimalStr !== '0') {
        errorDisplay.textContent = `Too short: ${decimalStr.length} digits (min ${MIN_PHONE_DIGITS})`;
        hiddenInput.value = '';
      } else if (decimalStr.length > MAX_PHONE_DIGITS) {
        errorDisplay.textContent = `Too long: ${decimalStr.length} digits (max ${MAX_PHONE_DIGITS})`;
        hiddenInput.value = '';
      } else if (decimalStr !== '0') {
        errorDisplay.textContent = `✓ Valid (${decimalStr.length} digits)`;
        hiddenInput.value = decimalStr;
      } else {
        errorDisplay.textContent = '';
        hiddenInput.value = '';
      }
    }

    // Initial validation
    updateBinaryPhone();
  })();
</script>

<script>
  // ── Birthday Dartboard ─────────────────────────────────────────────────────
  (function() {
    const dartboard = document.getElementById('dartboard');
    const dartboardContainer = document.getElementById('dartboardContainer');
    const totalScoreEl = document.getElementById('dartTotalScore');
    const dartCountEl = document.getElementById('dartCount');
    const dayOfYearEl = document.getElementById('dayOfYear');
    const calculatedBirthdayEl = document.getElementById('calculatedBirthday');
    const birthdayHidden = document.getElementById('birthdayHidden');
    const birthYearHidden = document.getElementById('birthYearHidden');
    const dartScoreHidden = document.getElementById('dartScoreHidden');
    const clearDartsBtn = document.getElementById('clearDartsBtn');
    const randomYearBtn = document.getElementById('randomYearBtn');

    // Dartboard configuration
    const CENTER = 200; // SVG viewBox is 400x400
    const RADIUS = 190;
    const INNER_BULL_RADIUS = 6;
    const OUTER_BULL_RADIUS = 16;
    const TRIPLE_INNER = 95;
    const TRIPLE_OUTER = 107;
    const DOUBLE_INNER = 130;
    const DOUBLE_OUTER = 140;

    // Standard dartboard number sequence (clockwise from top)
    const SECTIONS = [20, 1, 18, 4, 13, 6, 10, 15, 2, 17, 3, 19, 7, 16, 8, 11, 14, 9, 12, 5];

    // State
    let totalScore = 0;
    let dartCount = 0;
    let selectedYear = null;

    // Month lengths for day-of-year conversion
    const MONTH_LENGTHS = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];
    const MONTH_NAMES = ['January', 'February', 'March', 'April', 'May', 'June',
                         'July', 'August', 'September', 'October', 'November', 'December'];

    // Render the dartboard
    function renderDartboard() {
      const svg = dartboard;
      svg.innerHTML = ''; // Clear any existing content

      // Background circle
      const bgCircle = createSVGCircle(CENTER, CENTER, RADIUS, '#1a1a1a');
      svg.appendChild(bgCircle);

      // Draw each section
      for (let i = 0; i < 20; i++) {
        const startAngle = (i * 18 - 99) * Math.PI / 180; // -99 to start at top with 20
        const endAngle = ((i + 1) * 18 - 99) * Math.PI / 180;

        // Colors alternate
        const isBlack = i % 2 === 0;
        const singleColor = isBlack ? '#1a1a1a' : '#f5f5dc';
        const tripleColor = isBlack ? '#e74c3c' : '#2ecc71';
        const doubleColor = isBlack ? '#e74c3c' : '#2ecc71';

        // Single area (outer)
        svg.appendChild(createSectionPath(startAngle, endAngle, OUTER_BULL_RADIUS, TRIPLE_INNER, singleColor));
        // Triple ring
        svg.appendChild(createSectionPath(startAngle, endAngle, TRIPLE_INNER, TRIPLE_OUTER, tripleColor));
        // Single area (inner)
        svg.appendChild(createSectionPath(startAngle, endAngle, TRIPLE_OUTER, DOUBLE_INNER, singleColor));
        // Double ring
        svg.appendChild(createSectionPath(startAngle, endAngle, DOUBLE_INNER, DOUBLE_OUTER, doubleColor));
      }

      // Outer bull (green)
      svg.appendChild(createSVGCircle(CENTER, CENTER, OUTER_BULL_RADIUS, '#2ecc71'));

      // Inner bull (red)
      svg.appendChild(createSVGCircle(CENTER, CENTER, INNER_BULL_RADIUS, '#e74c3c'));

      // Wire/frame (circles)
      [OUTER_BULL_RADIUS, INNER_BULL_RADIUS, TRIPLE_INNER, TRIPLE_OUTER, DOUBLE_INNER, DOUBLE_OUTER].forEach(r => {
        svg.appendChild(createSVGCircle(CENTER, CENTER, r, 'none', '#888', 1));
      });

      // Section numbers
      for (let i = 0; i < 20; i++) {
        // Each number is centered in its section
        // Section 0 (20) is at top (-90 degrees), each section is 18 degrees
        const angleDeg = (i * 18 - 90); // Center of each section
        const angleRad = angleDeg * Math.PI / 180;
        const x = CENTER + (DOUBLE_OUTER + 20) * Math.cos(angleRad);
        const y = CENTER + (DOUBLE_OUTER + 20) * Math.sin(angleRad);

        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', x);
        text.setAttribute('y', y);
        text.setAttribute('text-anchor', 'middle');
        text.setAttribute('dominant-baseline', 'central');
        text.setAttribute('fill', '#fff');
        text.setAttribute('font-size', '16');
        text.setAttribute('font-weight', 'bold');
        text.setAttribute('font-family', 'Arial, sans-serif');
        text.textContent = SECTIONS[i];
        svg.appendChild(text);
      }
    }

    function createSVGCircle(cx, cy, r, fill, stroke = 'none', strokeWidth = 1) {
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', cx);
      circle.setAttribute('cy', cy);
      circle.setAttribute('r', r);
      circle.setAttribute('fill', fill);
      circle.setAttribute('stroke', stroke);
      circle.setAttribute('stroke-width', strokeWidth);
      return circle;
    }

    function createSectionPath(startAngle, endAngle, innerR, outerR, color) {
      const x1 = CENTER + innerR * Math.cos(startAngle);
      const y1 = CENTER + innerR * Math.sin(startAngle);
      const x2 = CENTER + outerR * Math.cos(startAngle);
      const y2 = CENTER + outerR * Math.sin(startAngle);
      const x3 = CENTER + outerR * Math.cos(endAngle);
      const y3 = CENTER + outerR * Math.sin(endAngle);
      const x4 = CENTER + innerR * Math.cos(endAngle);
      const y4 = CENTER + innerR * Math.sin(endAngle);

      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', `M ${x1} ${y1} L ${x2} ${y2} A ${outerR} ${outerR} 0 0 1 ${x3} ${y3} L ${x4} ${y4} A ${innerR} ${innerR} 0 0 0 ${x1} ${y1} Z`);
      path.setAttribute('fill', color);
      path.setAttribute('stroke', '#888');
      path.setAttribute('stroke-width', '0.5');
      return path;
    }

    // Calculate score based on position
    function calculateScore(x, y) {
      const dx = x - CENTER;
      const dy = y - CENTER;
      const distance = Math.sqrt(dx * dx + dy * dy);

      // Check if outside the board
      if (distance > DOUBLE_OUTER) {
        return 0; // Miss
      }

      // Inner bull
      if (distance <= INNER_BULL_RADIUS) {
        return 50;
      }

      // Outer bull
      if (distance <= OUTER_BULL_RADIUS) {
        return 25;
      }

      // Calculate which section (1-20)
      let angle = Math.atan2(dy, dx) * 180 / Math.PI;
      angle = (angle + 99) % 360; // Adjust so 20 is at top
      if (angle < 0) angle += 360;

      const sectionIndex = Math.floor(angle / 18) % 20;
      const baseScore = SECTIONS[sectionIndex];

      // Determine multiplier
      if (distance >= TRIPLE_INNER && distance <= TRIPLE_OUTER) {
        return baseScore * 3;
      } else if (distance >= DOUBLE_INNER && distance <= DOUBLE_OUTER) {
        return baseScore * 2;
      } else {
        return baseScore;
      }
    }

    // Convert day of year to month and day
    function dayOfYearToDate(dayOfYear) {
      let remainingDays = dayOfYear;
      for (let month = 0; month < 12; month++) {
        if (remainingDays <= MONTH_LENGTHS[month]) {
          return { month: month + 1, day: remainingDays, monthName: MONTH_NAMES[month] };
        }
        remainingDays -= MONTH_LENGTHS[month];
      }
      return { month: 12, day: 31, monthName: 'December' };
    }

    // Update the birthday display
    function updateBirthdayDisplay() {
      const dayOfYear = (totalScore % 365) + 1;
      const date = dayOfYearToDate(dayOfYear);

      dayOfYearEl.textContent = dayOfYear;

      if (selectedYear) {
        calculatedBirthdayEl.textContent = `${date.monthName} ${date.day}, ${selectedYear}`;
        calculatedBirthdayEl.classList.add('complete');
        birthdayHidden.value = `${date.month}-${date.day}`;
        birthYearHidden.value = selectedYear;
      } else {
        calculatedBirthdayEl.textContent = `${date.monthName} ${date.day} - Pick a year!`;
        calculatedBirthdayEl.classList.remove('complete');
        birthdayHidden.value = `${date.month}-${date.day}`;
      }

      dartScoreHidden.value = totalScore;
    }

    // Hover shake effect (gentle after 1s, violent after 2s)
    let gentleTimer = null;
    let wildTimer = null;

    dartboard.addEventListener('mouseenter', function() {
      gentleTimer = setTimeout(() => {
        dartboard.classList.add('aiming');
      }, 1000);

      wildTimer = setTimeout(() => {
        dartboard.classList.remove('aiming');
        dartboard.classList.add('aiming-wild');
      }, 2000);
    });

    dartboard.addEventListener('mouseleave', function() {
      if (gentleTimer) {
        clearTimeout(gentleTimer);
        gentleTimer = null;
      }
      if (wildTimer) {
        clearTimeout(wildTimer);
        wildTimer = null;
      }
      dartboard.classList.remove('aiming');
      dartboard.classList.remove('aiming-wild');
    });

    // Handle dartboard click
    dartboard.addEventListener('click', function(e) {
      // Add aiming shake effect
      dartboard.classList.add('aiming');

      setTimeout(() => {
        dartboard.classList.remove('aiming');

        const rect = dartboard.getBoundingClientRect();
        const scaleX = 400 / rect.width;
        const scaleY = 400 / rect.height;

        const svgX = (e.clientX - rect.left) * scaleX;
        const svgY = (e.clientY - rect.top) * scaleY;

        const score = calculateScore(svgX, svgY);

        totalScore += score;
        dartCount++;

        totalScoreEl.textContent = totalScore;
        dartCountEl.textContent = dartCount;

        updateBirthdayDisplay();
      }, 150);
    });

    // Clear darts button
    clearDartsBtn.addEventListener('click', function() {
      totalScore = 0;
      dartCount = 0;
      selectedYear = null;

      totalScoreEl.textContent = '0';
      dartCountEl.textContent = '0';
      dayOfYearEl.textContent = '-';
      calculatedBirthdayEl.textContent = 'Throw darts & pick a year!';
      calculatedBirthdayEl.classList.remove('complete');

      birthdayHidden.value = '';
      birthYearHidden.value = '';
      dartScoreHidden.value = '';

      randomYearBtn.textContent = 'Random Year';
    });

    // Random year button
    randomYearBtn.addEventListener('click', function() {
      selectedYear = Math.floor(Math.random() * (2025 - 1950 + 1)) + 1950;
      randomYearBtn.textContent = selectedYear;
      updateBirthdayDisplay();

      // Briefly show the year on the button
      setTimeout(() => {
        randomYearBtn.textContent = 'Random Year';
      }, 1500);
    });

    // Initialize
    renderDartboard();
  })();
</script>

<script>
  // ── Updated form validation for birthday ─────────────────────────────────────
  document.querySelector('form').addEventListener('submit', function(e) {
    const dartScoreHidden = document.getElementById('dartScoreHidden');
    const birthYearHidden = document.getElementById('birthYearHidden');

    if (!dartScoreHidden.value || parseInt(dartScoreHidden.value) === 0) {
      e.preventDefault();
      alert('🎯 You must throw at least one dart to determine your birthday!');
      return false;
    }

    if (!birthYearHidden.value) {
      e.preventDefault();
      alert('📅 Please click "Random Year" to generate your birth year!');
      return false;
    }

    // Let the existing modal logic continue
    document.getElementById('nevemurchieModal').style.display = 'block';
    e.preventDefault();
  });
</script>
</body>
</html>