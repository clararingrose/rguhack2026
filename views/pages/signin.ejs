<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/assets/styles.css" id="mainStylesheet">
  <style id="inlineStyles">
    #myVideo {
            position: fixed;
            right: 0;
            bottom: 0;
            min-width: 100%;
            min-height: 100%;
            z-index: -1;
        }

    /* NeveMurchie Password Warning Modal */
    .nevemurchie-modal {
      display: none;
      position: fixed;
      z-index: 9999999;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.8);
      animation: fadeIn 0.3s;
    }

    .nevemurchie-modal-content {
      background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
      margin: 15% auto;
      padding: 30px;
      border: 5px solid #000;
      width: 80%;
      max-width: 500px;
      border-radius: 20px;
      box-shadow: 0 0 50px rgba(255, 107, 107, 0.8);
      animation: slideIn 0.3s, shake 0.5s infinite;
      text-align: center;
    }

    .nevemurchie-modal-content h2 {
      color: white;
      font-size: 28px;
      margin-bottom: 20px;
      text-shadow: 3px 3px 0 #000;
    }

    .nevemurchie-modal-content p {
      color: white;
      font-size: 18px;
      margin-bottom: 25px;
      font-weight: bold;
    }

    .nevemurchie-buttons {
      display: flex;
      gap: 15px;
      justify-content: center;
    }

    .nevemurchie-btn {
      padding: 15px 30px;
      font-size: 18px;
      font-weight: bold;
      border: 3px solid #000;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.3s;
    }

    .nevemurchie-btn.yes {
      background: #27ae60;
      color: white;
    }

    .nevemurchie-btn.yes:hover {
      background: #2ecc71;
      transform: scale(1.1);
    }

    .nevemurchie-btn.no {
      background: #c0392b;
      color: white;
    }

    .nevemurchie-btn.no:hover {
      background: #e74c3c;
      transform: scale(1.1);
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes slideIn {
      from { transform: translateY(-50px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    @keyframes shake {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(-1deg); }
      75% { transform: rotate(1deg); }
    }

    /* ── Profile picture picker ── */
    .profile-pic-picker {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin: 8px 0 18px;
    }

    .profile-pic-option {
      position: relative;
      cursor: pointer;
      border-radius: 50%;
      display: block;
    }

    /* hide the actual radio button */
    .profile-pic-option input[type="radio"] {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }

    .profile-pic-option img {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid transparent;
      transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
      display: block;
    }

    .profile-pic-option img:hover {
      border-color: #aaa;
      transform: scale(1.07);
    }

    /* tick overlay — hidden by default */
    .profile-pic-tick {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      color: #fff;
      background: rgba(0,0,0,0.45);
      opacity: 0;
      transition: opacity 0.15s;
      pointer-events: none;
    }

    /* selected state */
    .profile-pic-option input[type="radio"]:checked ~ img {
      border-color: #4CAF50;
      box-shadow: 0 0 0 3px rgba(76,175,80,0.35);
      transform: scale(1.1);
    }

    .profile-pic-option input[type="radio"]:checked ~ .profile-pic-tick {
      opacity: 1;
    }
  </style>
</head>

<body>
<%- include('../partials/nav') %>

    <video autoplay muted loop id="myVideo">
        <source src="assets/fire.mp4" type="video/mp4">
    </video>

    <!-- Color Blind Mode Toggle -->
