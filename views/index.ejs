<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <link rel="stylesheet" href="/assets/styles.css">
    <style>
        /* Ouija Board Styles */
        .ouija-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(ellipse at center, #1a0a0a 0%, #0a0505 50%, #000 100%);
            z-index: 10000;
            animation: fadeIn 0.5s ease-in;
        }

        .ouija-modal.active {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .ouija-board {
            position: relative;
            width: 90vw;
            max-width: 800px;
            height: 80vh;
            max-height: 600px;
            background: linear-gradient(135deg, #2d1810 0%, #1a0f0a 50%, #2d1810 100%);
            border-radius: 20px;
            box-shadow:
                0 0 50px rgba(128, 0, 128, 0.3),
                0 0 100px rgba(75, 0, 130, 0.2),
                inset 0 0 100px rgba(0, 0, 0, 0.5),
                inset 0 0 20px rgba(139, 69, 19, 0.3);
            border: 8px solid #3d2817;
            padding: 30px;
            font-family: 'Georgia', serif;
            overflow: hidden;
        }

        .ouija-board::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" /><feColorMatrix type="saturate" values="0" /></filter><rect width="100%" height="100%" filter="url(%23noise)" opacity="0.1"/></svg>');
            pointer-events: none;
            opacity: 0.3;
        }

        .ouija-letters-container {
            position: relative;
            width: 100%;
            height: 300px;
            margin-top: 20px;
        }

        .ouija-letters-arc {
            position: relative;
            width: 100%;
            height: 100%;
        }

        .ouija-letter {
            position: absolute;
            font-size: 28px;
            font-weight: bold;
            color: #d4af37;
            text-shadow:
                0 0 10px rgba(212, 175, 55, 0.5),
                0 0 20px rgba(212, 175, 55, 0.3),
                2px 2px 4px rgba(0, 0, 0, 0.8);
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Times New Roman', serif;
            letter-spacing: 2px;
            transform-origin: center;
        }

        .ouija-letter:hover {
            color: #ff6b6b;
            text-shadow:
                0 0 15px rgba(255, 107, 107, 0.8),
                0 0 30px rgba(255, 107, 107, 0.5),
                0 0 45px rgba(139, 0, 139, 0.3);
            transform: scale(1.2);
        }

        .ouija-letter.selected {
            color: #9b59b6;
            animation: letterSelect 0.3s ease;
        }

        @keyframes letterSelect {
            0% { transform: scale(1); }
            50% { transform: scale(1.5); color: #fff; }
            100% { transform: scale(1); }
        }

        .ouija-numbers {
            position: absolute;
            bottom: 120px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 8px;
        }

        .ouija-number {
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #d4af37;
            font-size: 16px;
            font-weight: bold;
            text-shadow: 0 0 5px rgba(212, 175, 55, 0.5);
        }

        .ouija-words {
            position: absolute;
            bottom: 50px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-around;
            align-items: center;
        }

        .ouija-word {
            font-size: 18px;
            font-weight: bold;
            color: #8b4513;
            text-shadow: 0 0 5px rgba(139, 69, 19, 0.5);
            cursor: pointer;
            padding: 10px 15px;
            border: 2px solid #5d3a1a;
            border-radius: 5px;
            transition: all 0.3s ease;
        }

        .ouija-word:hover {
            color: #9b59b6;
            border-color: #9b59b6;
            box-shadow: 0 0 15px rgba(155, 89, 182, 0.5);
        }

        .planchette {
            position: absolute;
            width: 120px;
            height: 150px;
            pointer-events: none;
            z-index: 100;
            transition: transform 0.1s ease;
            filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.8));
        }

        .planchette svg {
            width: 100%;
            height: 100%;
        }

        .planchette-window {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            border: 3px solid #5d3a1a;
            box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(2px);
        }

        .planchette.shaking {
            animation: shake 0.1s infinite;
        }

        @keyframes shake {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            25% { transform: translate(-2px, 2px) rotate(-1deg); }
            50% { transform: translate(2px, -2px) rotate(1deg); }
            75% { transform: translate(-2px, -2px) rotate(-1deg); }
        }

        .ouija-current-value {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 24px;
            color: #9b59b6;
            text-shadow:
                0 0 10px rgba(155, 89, 182, 0.8),
                0 0 20px rgba(155, 89, 182, 0.5);
            background: rgba(0, 0, 0, 0.6);
            padding: 15px 30px;
            border-radius: 10px;
            border: 2px solid #5d3a1a;
            min-width: 200px;
            text-align: center;
            font-family: 'Courier New', monospace;
            letter-spacing: 3px;
        }

        .ouija-current-value .cursor {
            display: inline-block;
            width: 2px;
            height: 24px;
            background: #9b59b6;
            margin-left: 2px;
            animation: blink 1s infinite;
            vertical-align: middle;
        }

        @keyframes blink {
            0%, 50% { opacity: 1; }
            51%, 100% { opacity: 0; }
        }

        .ouija-instructions {
            position: absolute;
            bottom: 10px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 12px;
            color: #666;
            text-align: center;
            width: 90%;
            line-height: 1.6;
        }

        .ouija-warning {
            display: block;
            color: #9b59b6;
            font-style: italic;
            margin-top: 5px;
            animation: flicker 3s infinite;
        }

        @keyframes flicker {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
            75% { opacity: 0.9; }
        }

        .ghostly-flash {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle, rgba(155, 89, 182, 0.3) 0%, transparent 70%);
            pointer-events: none;
            opacity: 0;
            animation: ghostFlash 0.5s ease-out;
        }

        @keyframes ghostFlash {
            0% { opacity: 1; }
            100% { opacity: 0; }
        }

        .spooky-message {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 20px;
            color: #9b59b6;
            text-shadow: 0 0 20px rgba(155, 89, 182, 0.8);
            background: rgba(0, 0, 0, 0.9);
            padding: 20px 40px;
            border-radius: 10px;
            border: 2px solid #5d3a1a;
            z-index: 200;
            animation: spookyAppear 0.3s ease-out;
            pointer-events: none;
        }

        @keyframes spookyAppear {
            0% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
            100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
        }

        .ouija-field-indicator {
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 14px;
            color: #d4af37;
            text-shadow: 0 0 5px rgba(212, 175, 55, 0.5);
            background: #1a0f0a;
            padding: 5px 15px;
            border-radius: 5px;
            border: 1px solid #5d3a1a;
        }

        .ouija-start-btn {
            background: linear-gradient(135deg, #4a0080 0%, #2d0a4a 100%);
            border: 2px solid #9b59b6;
            color: #fff;
            padding: 12px 24px;
            font-size: 16px;
            cursor: pointer;
            border-radius: 8px;
            transition: all 0.3s ease;
            text-shadow: 0 0 10px rgba(155, 89, 182, 0.5);
            box-shadow: 0 0 15px rgba(155, 89, 182, 0.3);
        }

        .ouija-start-btn:hover {
            background: linear-gradient(135deg, #6a00a0 0%, #4d0a6a 100%);
            box-shadow: 0 0 25px rgba(155, 89, 182, 0.5);
            transform: scale(1.05);
        }

        .ouija-display {
            background: rgba(0, 0, 0, 0.3);
            border: 2px solid #5d3a1a;
            border-radius: 8px;
            padding: 12px 16px;
            min-height: 44px;
            font-family: 'Courier New', monospace;
            font-size: 18px;
            color: #d4af37;
            text-shadow: 0 0 5px rgba(212, 175, 55, 0.3);
            margin-top: 5px;
            letter-spacing: 2px;
        }

        .ouija-display.empty {
            color: #666;
            font-style: italic;
        }

        .fog-effect {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background:
                radial-gradient(ellipse at 20% 80%, rgba(75, 0, 130, 0.1) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(128, 0, 128, 0.1) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(75, 0, 130, 0.05) 0%, transparent 70%);
            pointer-events: none;
            animation: fogMove 10s infinite ease-in-out;
        }

        @keyframes fogMove {
            0%, 100% { opacity: 0.5; transform: translate(0, 0); }
            50% { opacity: 0.8; transform: translate(10px, -10px); }
        }

        .close-modal-btn {
            position: absolute;
            top: 15px;
            right: 15px;
            background: rgba(0, 0, 0, 0.6);
            border: 2px solid #9b59b6;
            color: #9b59b6;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            z-index: 300;
        }

        .close-modal-btn:hover {
            background: rgba(155, 89, 182, 0.3);
            box-shadow: 0 0 15px rgba(155, 89, 182, 0.5);
        }
    </style>
</head>
<body>
<!-- MALICIOUS SPINNING NAVIGATION -->
<nav class="malicious-nav" id="maliciousNav">
    <div class="malicious-nav-items">
        <a href="/" class="malicious-nav-item" style="transform: rotate(0deg) translateY(-100px) rotate(0deg);">Home</a>
        <a href="/blog" class="malicious-nav-item" style="transform: rotate(51deg) translateY(-100px) rotate(-51deg);">Blog</a>
        <a href="#about" class="malicious-nav-item" style="transform: rotate(102deg) translateY(-100px) rotate(-102deg);">About</a>
        <a href="#help" class="malicious-nav-item" style="transform: rotate(180deg) translateY(-100px) rotate(-180deg);">Help</a>
        <a href="#contact" class="malicious-nav-item" style="transform: rotate(225deg) translateY(-100px) rotate(-225deg);">Contact</a>
        <a href="#settings" class="malicious-nav-item" style="transform: rotate(270deg) translateY(-100px) rotate(-270deg);">Settings</a>
        <a href="/wrapped" class="malicious-nav-item" style="transform: rotate(315deg) translateY(-100px) rotate(-315deg);">Wrapped</a>
        <div class="malicious-nav-center">🌍</div>
    </div>
</nav>

<%- include("partials/curtains.ejs") %>
    <div class="container" id="home">
        <h1>🌍 Carbon Calculator</h1>
        <p class="subtitle">Find the most exciting way to travel! 🔥</p>

        <div class="input-section" id="calculator">
            <!-- Boring Mode Inputs (hidden by default) -->
            <div id="boringModeInputs" style="display: none;">
                <div class="form-group">
                    <label for="originBoring">Origin</label>
                    <input type="text" id="originBoring" class="boring-input" placeholder="Enter origin (e.g., London, UK)">
                </div>
                <div class="form-group">
                    <label for="destinationBoring">Destination</label>
                    <input type="text" id="destinationBoring" class="boring-input" placeholder="Enter destination (e.g., Paris, France)">
                </div>
            </div>

            <!-- Fun Mode Inputs -->
            <div id="funModeInputs">
                <div class="form-group">
                    <label for="origin">Origin</label>
                    <div class="ddr-display empty" id="originDisplay">Dance to input location...</div>
                    <button class="ddr-start-btn" data-field="origin" id="originBtn">💃 DDR Mode 💃</button>
                    <input type="hidden" id="origin" value="">
                </div>
                <div class="form-group">
                    <label for="destination">Destination</label>
                    <div class="ddr-display empty" id="destinationDisplay">Dance to input destination...</div>
                    <button class="ddr-start-btn" data-field="destination" id="destinationBtn">💃 DDR Mode 💃</button>
                    <input type="hidden" id="destination" value="">
                </div>
            </div>

            <!-- Mode Toggle Buttons -->
            <div style="text-align: center;">
                <button class="mode-toggle-btn" id="modeToggle">Switch to 👻 Ouija Mode</button>
                <button class="boring-mode-btn" id="boringModeToggle">😴 Boring Mode</button>
            </div>
        </div>
            <div class="form-group">
                <label for="date">Departure Date</label>
                <div class="date-wrapper">
                    <button id="date">
                        <span class="date-display">Select Date</span>
                        <span class="date-icon">🌍</span>
                        <input type="checkbox">
                        <div id="datePicker">
                            <svg viewBox="0 0 350 166">
                                <ellipse id="ellipse" cx="175" cy="83" rx="150" ry="73"
                                style="fill-opacity: 0;stroke:yellow;stroke-width:0.5" />
                                <image id="earth" height="15" width="15" href="/assets/earth.png"></image>
                                <image id="sun" x="105" y="68" height="30" width="30" href="/assets/sun.png"></image>
                            </svg>
                        </div>
                    </button>
                </div>
            </div>
            <button class="calculate-btn" id="calculateBtn">Calculate Emissions</button>
        </div>

        <div id="errorContainer"></div>

        <div class="results-section" id="resultsSection">
            <div class="journey-info">
                <h2>Journey Distance</h2>
                <div class="distance" id="distanceValue">0</div>
                <span class="distance-unit">kilometres</span>
            </div>

            <div class="transport-list" id="transportList"></div>
        </div>
    </div>

    <!-- Achievement Spam Container -->
    <div class="achievement-spam" id="achievementSpam"></div>

    <!-- Cookie Banner -->
    <div class="cookie-banner" id="cookieBanner">
        <div class="cookie-content">
            <div class="cookie-title">🍪 We Love Cookies!</div>
            <p class="cookie-text">We use cookies to track your every move, harvest your personal data, and sell your personal information to the highest bidder</p>
            <div class="cookie-buttons">
                <button class="cookie-btn cookie-btn-accept" id="acceptCookies">Accept All</button>
                <button class="cookie-btn cookie-btn-decline" id="declineCookies">Decline</button>
            </div>
        </div>
    </div>

    <!-- Ouija Board Modal -->
    <div class="ouija-modal" id="ouijaModal">
        <div class="ouija-board" id="ouijaBoard">
            <button class="close-modal-btn" id="closeModalBtn">×</button>
            <div class="fog-effect"></div>
            <div class="ouija-field-indicator" id="ouijaFieldIndicator">ORIGIN</div>
            <div class="ouija-current-value" id="ouijaValue">_ <span class="cursor"></span></div>

            <div class="ouija-letters-container">
                <div class="ouija-letters-arc" id="ouijaLettersArc"></div>
            </div>

            <div class="ouija-numbers" id="ouijaNumbers"></div>

            <div class="ouija-words">
                <div class="ouija-word" data-char=" ">YES</div>
                <div class="ouija-word" data-char=" ">NO</div>
                <div class="ouija-word" data-char=" ">GOODBYE</div>
            </div>

            <div class="planchette" id="planchette">
                <svg viewBox="0 0 120 150">
                    <defs>
                        <linearGradient id="woodGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#5d3a1a;stop-opacity:1" />
                            <stop offset="50%" style="stop-color:#8b5a2b;stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#3d2817;stop-opacity:1" />
                        </linearGradient>
                        <filter id="shadow">
                            <feDropShadow dx="2" dy="4" stdDeviation="3" flood-opacity="0.5"/>
                        </filter>
                    </defs>
                    <ellipse cx="60" cy="75" rx="50" ry="60" fill="url(#woodGradient)" filter="url(#shadow)" stroke="#3d2817" stroke-width="3"/>
                    <ellipse cx="60" cy="50" rx="25" ry="20" fill="rgba(255,255,255,0.15)" stroke="#5d3a1a" stroke-width="2"/>
                    <circle cx="60" cy="20" r="8" fill="#5d3a1a" filter="url(#shadow)"/>
                </svg>
                <div class="planchette-window"></div>
            </div>

            <div class="ouija-instructions">
                Guide the planchette with your mouse to spell your location<br>
                Press ENTER to finish | Press ESC to cancel<br>
                <span class="ouija-warning">⚠️ The spirits are restless tonight... ⚠️</span>
            </div>
        </div>
    </div>

    <!-- DDR Modal -->
    <div class="ddr-modal" id="ddrModal">
        <div class="ddr-game" id="ddrGame">
            <button class="close-modal-btn" id="closeDdrBtn" style="border-color: #ff0080; color: #ff0080;">×</button>
            <div class="ddr-field-indicator" id="ddrFieldIndicator">ORIGIN</div>
            <div class="ddr-current-value" id="ddrValue">_ <span class="cursor"></span></div>

            <!-- 4 lanes for arrows -->
            <div class="ddr-lanes" id="ddrLanes">
                <div class="ddr-lane" data-direction="left">
                    <div class="ddr-target-zone"></div>
                    <div class="ddr-arrow-target">←</div>
                </div>
                <div class="ddr-lane" data-direction="up">
                    <div class="ddr-target-zone"></div>
                    <div class="ddr-arrow-target">↑</div>
                </div>
                <div class="ddr-lane" data-direction="down">
                    <div class="ddr-target-zone"></div>
                    <div class="ddr-arrow-target">↓</div>
                </div>
                <div class="ddr-lane" data-direction="right">
                    <div class="ddr-target-zone"></div>
                    <div class="ddr-arrow-target">→</div>
                </div>
            </div>

            <!-- Letter display showing what each arrow does -->
            <div class="ddr-letter-hints">
                <div class="ddr-hint" data-direction="left">←: QWERTYUI</div>
                <div class="ddr-hint" data-direction="up">↑: ASDFGHJK</div>
                <div class="ddr-hint" data-direction="down">↓: ZXCVBNM</div>
                <div class="ddr-hint" data-direction="right">→: OPL SPACE</div>
            </div>

            <!-- Score/feedback -->
            <div class="ddr-score" id="ddrScore">Perfect: 0 | Miss: 0</div>

            <div class="ddr-instructions">
                💃 Press arrows when letters reach the target zone! 💃<br>
                Arrow keys or WASD | ENTER to finish | ESC to cancel<br>
                <span class="ddr-warning">⚠️ Don't miss the beat! ⚠️</span>
            </div>

            <!-- Mode switch button -->
            <button class="switch-to-ouija-btn" id="switchToOuija">
                👻 Too hard? Try Ouija Board 👻
            </button>
        </div>
    </div>

    <!-- Load JavaScript modules -->
    <script src="/js/shared-state.js"></script>
    <script src="/js/calculator.js"></script>
    <script src="/js/input-modes.js"></script>
    <script src="/js/date-picker.js"></script>
    <script src="/js/cookie-banner.js"></script>
    <script src="/js/malicious-nav.js"></script>
    <script src="/js/achievements.js"></script>
</body>
</html>
