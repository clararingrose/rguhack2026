<%- include("partials/curtains.ejs") %>
    <div class="container" id="home">
        <h1>🌍 Carbon Calculator</h1>
        <p class="subtitle">Find the most exciting way to travel! 🔥</p>

        <div class="input-section" id="calculator">
            <!-- Boring Mode Inputs (hidden by default) -->
            <div id="boringModeInputs" style="display: none;">
