        // Keyboard handlers for DDR
        document.addEventListener('keydown', (e) => {
            if (!ddrActive) return;

            const key = e.key.toLowerCase();

            // Arrow keys
            if (e.key === 'ArrowLeft') {
                e.preventDefault();
                handleArrowPress('left');
            } else if (e.key === 'ArrowUp') {
