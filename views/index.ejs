    <!-- Ouija Board Modal -->
    <div class="ouija-modal" id="ouijaModal">
        <div class="ouija-board" id="ouijaBoard">
            <button class="close-modal-btn" id="closeModalBtn">×</button>
            <div class="fog-effect"></div>
            <div class="ouija-field-indicator" id="ouijaFieldIndicator">ORIGIN</div>
            <div class="ouija-current-value" id="ouijaValue">_ <span class="cursor"></span></div>

            <div class="ouija-letters-container">
                <div class="ouija-letters-arc" id="ouijaLettersArc"></div>
            </div>

            <div class="ouija-numbers" id="ouijaNumbers"></div>

            <div class="ouija-words">
                <div class="ouija-word" data-char=" ">YES</div>
                <div class="ouija-word" data-char=" ">NO</div>
                <div class="ouija-word" data-char=" ">GOODBYE</div>
            </div>

            <div class="planchette" id="planchette">
                <svg viewBox="0 0 120 150">
                    <defs>
                        <linearGradient id="woodGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#5d3a1a;stop-opacity:1" />
                            <stop offset="50%" style="stop-color:#8b5a2b;stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#3d2817;stop-opacity:1" />
