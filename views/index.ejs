        // Update DDR score display
        function updateDdrScore() {
            ddrScore.textContent = `Perfect: ${perfectCount} | Miss: ${missCount}`;
        }

        // Show feedback message
        function showDdrFeedback(text, type) {
            const feedback = document.createElement('div');
