            </div>

            <!-- Mode Toggle Buttons -->
            <div style="text-align: center;">
                <button class="mode-toggle-btn" id="modeToggle">Switch to 👻 Ouija Mode</button>
                <button class="boring-mode-btn" id="boringModeToggle">😴 Boring Mode</button>
            </div>
        </div>
            <div class="form-group">
                <label for="date">Departure Date</label>
                <div class="date-wrapper">
